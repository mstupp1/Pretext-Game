{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Lexicon Crossing",
  "version": "1.0.0",
  "identifier": "com.mylesstupp.lexiconcrossing",
  "build": {
    "frontendDist": "../dist-desktop",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev:desktop-frontend",
    "beforeBuildCommand": "npm run build:desktop"
  },
  "app": {
    "windows": [
      {
        "title": "Lexicon Crossing",
        "label": "main",
        "width": 1280,
        "height": 920,
        "minWidth": 1040,
        "minHeight": 760,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "connect-src": [
          "'self'",
          "ipc:",
          "http://ipc.localhost"
        ],
        "font-src": [
          "'self'",
          "asset:",
          "http://asset.localhost",
          "data:"
        ],
        "img-src": [
          "'self'",
          "asset:",
          "http://asset.localhost",
          "data:",
          "blob:"
        ],
        "media-src": [
          "'self'",
          "asset:",
          "http://asset.localhost",
          "data:",
          "blob:"
        ],
        "style-src": [
          "'self'",
          "'unsafe-inline'"
        ]
      },
      "devCsp": "default-src 'self' http://localhost:5173 ipc: http://ipc.localhost ws://localhost:5173 ws://localhost:1421; connect-src 'self' ipc: http://ipc.localhost http://localhost:5173 ws://localhost:5173 ws://localhost:1421; img-src 'self' asset: http://asset.localhost data: blob: http://localhost:5173; media-src 'self' asset: http://asset.localhost data: blob: http://localhost:5173; font-src 'self' asset: http://asset.localhost data: http://localhost:5173; style-src 'self' 'unsafe-inline' http://localhost:5173; script-src 'self' 'unsafe-eval' http://localhost:5173"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
